{
  "name": "@querobroapp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start:tsx": "tsx src/main.ts",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "pnpm prisma:seed:dev",
    "prisma:seed:dev": "NODE_ENV=development DATABASE_URL=file:./dev.db prisma db seed",
    "prisma:generate:dev": "NODE_ENV=development DATABASE_URL=file:./dev.db prisma generate",
    "prisma:migrate:dev": "NODE_ENV=development DATABASE_URL=file:./dev.db prisma migrate dev",
    "orders:reprice:official": "tsx scripts/reprice-orders-official.ts",
    "prisma:generate:prod": "NODE_ENV=production DATABASE_URL=\"$DATABASE_URL_PROD\" prisma generate --schema prisma/schema.prod.prisma",
    "prisma:push:prod": "NODE_ENV=production DATABASE_URL=\"$DATABASE_URL_PROD\" prisma db push --schema prisma/schema.prod.prisma",
    "prisma:migrate:prod": "pnpm prisma:push:prod"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^7.5.0",
    "@querobroapp/shared": "workspace:*",
    "helmet": "^8.1.0",
    "libphonenumber-js": "^1.12.40",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "0.34.5",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^6.0.2"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm prisma/seed.ts"
  }
}
