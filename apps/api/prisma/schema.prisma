generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id           Int      @id @default(autoincrement())
  publicNumber Int?     @unique
  name         String
  firstName    String?
  lastName     String?
  activePhoneKey String? @unique
  phone        String?
  address      String?
  addressLine1 String?
  addressLine2 String?
  neighborhood String?
  city         String?
  state        String?
  postalCode   String?
  country      String?
  placeId      String?
  lat          Float?
  lng          Float?
  deliveryNotes String?
  createdAt    DateTime @default(now())
  deletedAt    DateTime?
  orders       Order[]
  addresses    CustomerAddress[]

  @@index([name])
  @@index([phone])
}

model CustomerAddress {
  id            Int      @id @default(autoincrement())
  customerId     Int
  address       String?
  addressLine1  String?
  addressLine2  String?
  neighborhood  String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  placeId       String?
  lat           Float?
  lng           Float?
  deliveryNotes String?
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, isPrimary])
  @@index([customerId, createdAt])
  @@index([placeId])
}

model Product {
  id                   Int      @id @default(autoincrement())
  name                 String
  category             String?
  unit                 String?
  price                Float
  imageUrl             String?
  drawerNote           String?
  inventoryItemId      Int?     @unique
  inventoryQtyPerSaleUnit Float?
  active               Boolean  @default(true)
  salesLimitEnabled    Boolean  @default(false)
  salesLimitBoxes      Int?
  salesLimitActivatedAt DateTime?
  createdAt            DateTime @default(now())
  items                OrderItem[]
  boms                 Bom[]
  inventoryItem        InventoryItem? @relation("CompanionInventoryItem", fields: [inventoryItemId], references: [id])

  @@index([name])
  @@index([category])
  @@index([active])
}

model Coupon {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  discountPct Float
  usageLimitPerCustomer Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

model Order {
  id                 Int                 @id @default(autoincrement())
  publicNumber       Int?                @unique
  customerId         Int
  customerName       String?
  customerPhone      String?
  customerAddress    String?
  customerAddressLine1 String?
  customerAddressLine2 String?
  customerNeighborhood String?
  customerCity       String?
  customerState      String?
  customerPostalCode String?
  customerCountry    String?
  customerPlaceId    String?
  customerLat        Float?
  customerLng        Float?
  customerDeliveryNotes String?
  status             String              @default("ABERTO")
  fulfillmentMode    String              @default("DELIVERY")
  subtotal           Float               @default(0)
  deliveryFee        Float               @default(0)
  deliveryProvider   String              @default("NONE")
  deliveryFeeSource  String              @default("NONE")
  deliveryQuoteStatus String             @default("NOT_REQUIRED")
  deliveryQuoteRef   String?
  deliveryQuoteExpiresAt DateTime?
  discount           Float               @default(0)
  couponCode         String?
  total              Float               @default(0)
  notes              String?
  scheduledAt        DateTime?
  createdAt          DateTime            @default(now())
  customer           Customer            @relation(fields: [customerId], references: [id])
  items              OrderItem[]
  payments           Payment[]
  inventoryMovements InventoryMovement[]

  @@index([customerId])
  @@index([customerId, couponCode])
  @@index([couponCode])
  @@index([status])
  @@index([fulfillmentMode])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  unitPrice Float
  total     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id          Int           @id @default(autoincrement())
  orderId     Int
  amount      Float
  method      String
  status      String        @default("PENDENTE")
  paidAt      DateTime?
  dueDate     DateTime?
  providerRef String?
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model InventoryItem {
  id               Int      @id @default(autoincrement())
  name             String
  category         String
  unit             String
  purchasePackSize Float
  purchasePackCost Float     @default(0)
  leadTimeDays     Int?
  safetyStockQty   Float?
  reorderPointQty  Float?
  targetStockQty   Float?
  perishabilityDays Int?
  criticality      String?
  preferredSupplier String?
  createdAt        DateTime @default(now())
  movements        InventoryMovement[]
  bomItems         BomItem[]
  priceEntries     InventoryPriceEntry[]
  companionProduct Product?  @relation("CompanionInventoryItem")

  @@index([name])
  @@index([category])
}

model InventoryPriceEntry {
  id               Int      @id @default(autoincrement())
  itemId           Int
  purchasePackSize Float
  purchasePackCost Float
  sourceName       String?
  sourceUrl        String?
  note             String?
  effectiveAt      DateTime
  createdAt        DateTime @default(now())
  item             InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, effectiveAt])
  @@index([effectiveAt])
}

model InventoryMovement {
  id        Int      @id @default(autoincrement())
  itemId    Int
  orderId   Int?
  type      String
  quantity  Float
  reason    String?
  source    String?
  sourceLabel String?
  unitCost  Float?
  createdAt DateTime @default(now())
  item      InventoryItem @relation(fields: [itemId], references: [id])
  order     Order?        @relation(fields: [orderId], references: [id])

  @@index([itemId])
  @@index([orderId])
  @@index([createdAt])
}

model Bom {
  id            Int      @id @default(autoincrement())
  productId     Int
  name          String
  saleUnitLabel String?
  yieldUnits    Float?
  product       Product  @relation(fields: [productId], references: [id])
  items         BomItem[]

  @@index([productId])
}

model BomItem {
  id             Int      @id @default(autoincrement())
  bomId          Int
  itemId         Int
  qtyPerRecipe   Float?
  qtyPerSaleUnit Float?
  qtyPerUnit     Float?
  bom            Bom          @relation(fields: [bomId], references: [id], onDelete: Cascade)
  item           InventoryItem @relation(fields: [itemId], references: [id])

  @@index([bomId])
  @@index([itemId])
}

model IdempotencyRecord {
  id           Int      @id @default(autoincrement())
  scope        String
  idemKey      String
  requestHash  String
  responseJson String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([scope, idemKey])
  @@index([expiresAt])
}

model SiteAnalyticsEvent {
  id             Int      @id @default(autoincrement())
  sessionId      String
  eventType      String
  path           String?
  href           String?
  label          String?
  referrerHost   String?
  referrerUrl    String?
  source         String?
  medium         String?
  campaign       String?
  deviceType     String?
  browser        String?
  os             String?
  locale         String?
  timezone       String?
  viewportWidth  Int?
  viewportHeight Int?
  screenWidth    Int?
  screenHeight   Int?
  metricName     String?
  metricValue    Float?
  metricUnit     String?
  navigationType String?
  metaJson       String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([eventType, createdAt])
  @@index([sessionId, createdAt])
  @@index([path, createdAt])
}

model PublicSequenceCounter {
  name      String @id
  nextValue Int
}

model OrderScheduleDayAvailability {
  id        Int      @id @default(autoincrement())
  dayKey    String
  windowKey String   @default("ALL_DAY")
  isOpen    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayKey, windowKey])
  @@index([dayKey, windowKey, isOpen])
}

model BankStatementImport {
  id                    Int      @id @default(autoincrement())
  source                String
  sourceLabel           String?
  fileName              String
  fileKind              String
  checksum              String   @unique
  emailSubject          String?
  periodStart           DateTime?
  periodEnd             DateTime?
  transactionCount      Int      @default(0)
  matchedPaymentsCount  Int      @default(0)
  unmatchedInflowsCount Int      @default(0)
  inflowTotal           Float    @default(0)
  outflowTotal          Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  latestTransactions    BankStatementTransaction[] @relation("LatestImport")

  @@index([createdAt])
  @@index([periodEnd])
}

model BankStatementClassificationOption {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  label         String
  baseCategory  String
  tone          String
  isOperational Boolean  @default(true)
  active        Boolean  @default(true)
  system        Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, sortOrder])
}

model BankStatementTransaction {
  id                    Int      @id @default(autoincrement())
  latestImportId        Int?
  bookedAt              DateTime
  amount                Float
  externalId            String   @unique
  description           String
  normalizedDescription String
  direction             String
  transactionKind       String
  category              String
  classificationCode    String?
  manualClassification  Boolean  @default(false)
  manualMatch           Boolean  @default(false)
  counterpartyName      String?
  isOperational         Boolean  @default(true)
  matchedPaymentId      Int?
  matchedOrderId        Int?
  rawJson               String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  latestImport          BankStatementImport? @relation("LatestImport", fields: [latestImportId], references: [id], onDelete: SetNull)

  @@index([latestImportId])
  @@index([bookedAt])
  @@index([category, bookedAt])
  @@index([classificationCode, bookedAt])
  @@index([matchedPaymentId])
  @@index([matchedOrderId])
}
