NODE_ENV=development
PORT=3001
HOST=127.0.0.1
DATABASE_URL=file:./dev.db
DATABASE_URL_PROD=postgresql://postgres:postgres@localhost:5432/querobroapp?schema=public
ENABLE_SWAGGER=false
APP_ALLOW_SWAGGER_IN_PROD=false
# Runtime default e fail-closed (auth on) quando APP_AUTH_ENABLED nao estiver definido.
# Manter false apenas para dev local em loopback.
APP_AUTH_ENABLED=false
APP_AUTH_TOKEN=
APP_AUTH_TOKENS=
APP_ALLOW_UNSAFE_AUTH_IN_PROD=false
# Escape explicito para permitir auth off com bind publico (nao recomendado).
APP_ALLOW_UNSAFE_AUTH_ON_PUBLIC_HOST=false
APP_CORS_ORIGINS=
