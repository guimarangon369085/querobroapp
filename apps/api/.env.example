NODE_ENV=development
PORT=3001
HOST=127.0.0.1
DATABASE_URL=file:./dev.db
DATABASE_URL_PROD=postgresql://postgres:postgres@localhost:5432/querobroapp?schema=public
ENABLE_SWAGGER=false
APP_ALLOW_SWAGGER_IN_PROD=false
# Runtime default e fail-closed (auth on) quando APP_AUTH_ENABLED nao estiver definido.
# Manter false apenas para dev local em loopback.
APP_AUTH_ENABLED=false
APP_AUTH_TOKEN=
APP_AUTH_TOKENS=
APP_ALLOW_UNSAFE_AUTH_IN_PROD=false
# Escape explicito para permitir auth off com bind publico (nao recomendado).
APP_ALLOW_UNSAFE_AUTH_ON_PUBLIC_HOST=false
APP_CORS_ORIGINS=
ORDER_FORM_BRIDGE_TOKEN=
PIX_PROVIDER=LOCAL_DEV
PIX_STATIC_KEY=
PIX_RECEIVER_NAME=QUERO BROA
PIX_RECEIVER_CITY=BELO HORIZONTE
PIX_DESCRIPTION_PREFIX=PEDIDO
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_CLOUD_API_BASE_URL=https://graph.facebook.com
DELIVERY_PICKUP_NAME=QUERO BROA
DELIVERY_PICKUP_PHONE=
DELIVERY_PICKUP_ADDRESS=
DELIVERY_MANUAL_FALLBACK_FEE=12
UBER_DIRECT_BASE_URL=
UBER_DIRECT_BEARER_TOKEN=
UBER_DIRECT_CUSTOMER_ID=
UBER_DIRECT_QUOTES_PATH=/delivery_quotes
UBER_DIRECT_DELIVERIES_PATH=/deliveries
