NODE_ENV=development
PORT=3001
HOST=127.0.0.1
DATABASE_URL=file:./dev.db
DATABASE_URL_PROD=postgresql://postgres:postgres@localhost:5432/querobroapp?schema=public
ENABLE_SWAGGER=false
APP_ALLOW_SWAGGER_IN_PROD=false
# Runtime default e fail-closed (auth on) quando APP_AUTH_ENABLED nao estiver definido.
# Manter false apenas para dev local em loopback.
APP_AUTH_ENABLED=false
APP_AUTH_TOKEN=
APP_AUTH_TOKENS=
APP_ALLOW_UNSAFE_AUTH_IN_PROD=false
# Escape explicito para permitir auth off com bind publico (nao recomendado).
APP_ALLOW_UNSAFE_AUTH_ON_PUBLIC_HOST=false
APP_CORS_ORIGINS=
ORDER_FORM_BRIDGE_TOKEN=
BUSINESS_BRAND_NAME=QUEROBROA
BUSINESS_LEGAL_NAME=65.756.685 GUILHERME MARANGON
BUSINESS_CNPJ=65756685000146
BUSINESS_OFFICIAL_PHONE=+55 11 99400-9584
BUSINESS_OFFICIAL_PHONE_DISPLAY=+55 11 99400-9584
BUSINESS_PIX_KEY=+5511994009584
BUSINESS_PICKUP_ADDRESS_LINE1=Alameda Jau, 731
BUSINESS_PICKUP_ADDRESS_LINE2=Apto 62
BUSINESS_NEIGHBORHOOD=Jardim Paulista
BUSINESS_CITY=Sao Paulo
BUSINESS_STATE=SP
BUSINESS_POSTAL_CODE=01420-001
BUSINESS_BANK_NAME=Nu Pagamentos S.A. - Instituicao de Pagamento
BUSINESS_BANK_CODE=260
BUSINESS_BANK_BRANCH=0001
BUSINESS_BANK_ACCOUNT=770733822-0
BUSINESS_BANK_ACCOUNT_HOLDER=65.756.685 GUILHERME MARANGON
PIX_PROVIDER=LOCAL_DEV
PIX_STATIC_KEY=+5511994009584
PIX_RECEIVER_NAME=QUEROBROA
PIX_RECEIVER_CITY=SAO PAULO
PIX_DESCRIPTION_PREFIX=PEDIDO
# Alerta operacional de novo pedido via ntfy e/ou webhook iOS (Pushcut/Shortcuts).
ORDER_ALERT_NTFY_TOPIC_URL=
ORDER_ALERT_NTFY_PRIORITY=5
ORDER_ALERT_NTFY_TAGS=bread,shopping_cart
ORDER_ALERT_WEBHOOK_URL=
ORDER_ALERT_WEBHOOK_BEARER_TOKEN=
ORDER_ALERT_WEBHOOK_TIMEOUT_MS=7000
ORDER_ALERT_OPERATIONS_URL=https://querobroa.com.br/pedidos
# Resumo diario via ntfy as 07:00 (horario de Sao Paulo), com links de WhatsApp por pedido.
ORDER_DAILY_DIGEST_ENABLED=true
ORDER_DAILY_DIGEST_SEND_AT_HOUR=7
ORDER_DAILY_DIGEST_NTFY_TOPIC_URL=
ORDER_DAILY_DIGEST_NTFY_PRIORITY=4
ORDER_DAILY_DIGEST_NTFY_TAGS=sunrise,bread,clipboard
ORDER_DAILY_DIGEST_OPERATIONS_URL=https://querobroa.com.br/confirmacoes
# Auto-confirmacao opcional via WhatsApp Cloud API para pedidos do site.
# Se houver template utilitario aprovado, prefira preencher TEMPLATE_NAME para uso fora da janela de 24h.
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_CLOUD_API_BASE_URL=https://graph.facebook.com
WHATSAPP_CLOUD_TIMEOUT_MS=15000
WHATSAPP_CLOUD_ORDER_CONFIRMATION_AUTO_SEND_ENABLED=false
WHATSAPP_CLOUD_ORDER_CONFIRMATION_TEMPLATE_NAME=
WHATSAPP_CLOUD_ORDER_CONFIRMATION_TEMPLATE_LANGUAGE=pt_BR
DELIVERY_PICKUP_NAME=QUERO BROA
DELIVERY_PICKUP_PHONE=+55 11 99400-9584
DELIVERY_PICKUP_ADDRESS=Alameda Jau, 731 - Sao Paulo - SP, Brasil
# Origem operacional fixa em codigo: Alameda Jau, 731 - Sao Paulo - SP, Brasil
# fallback manual usa a mesma faixa operacional: ate 10km cobra 12, acima disso 18
PIX_RECONCILIATION_LOOKBACK_DAYS=45
PIX_RECONCILIATION_ALLOW_UNIQUE_AMOUNT_FALLBACK=false
