NODE_ENV=development
PORT=3001
HOST=127.0.0.1
DATABASE_URL=file:./dev.db
DATABASE_URL_PROD=postgresql://postgres:postgres@localhost:5432/querobroapp?schema=public
ENABLE_SWAGGER=false
APP_ALLOW_SWAGGER_IN_PROD=false
# Runtime default e fail-closed (auth on) quando APP_AUTH_ENABLED nao estiver definido.
# Manter false apenas para dev local em loopback.
APP_AUTH_ENABLED=false
APP_AUTH_TOKEN=
APP_AUTH_TOKENS=
APP_ALLOW_UNSAFE_AUTH_IN_PROD=false
# Escape explicito para permitir auth off com bind publico (nao recomendado).
APP_ALLOW_UNSAFE_AUTH_ON_PUBLIC_HOST=false
APP_CORS_ORIGINS=
ORDER_FORM_BRIDGE_TOKEN=
PIX_PROVIDER=LOCAL_DEV
PIX_STATIC_KEY=
PIX_RECEIVER_NAME=QUERO BROA
PIX_RECEIVER_CITY=BELO HORIZONTE
PIX_DESCRIPTION_PREFIX=PEDIDO
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_CLOUD_API_BASE_URL=https://graph.facebook.com
# Alerta operacional de novo pedido no iPhone via WhatsApp e/ou webhook iOS (Pushcut/Shortcuts).
ORDER_ALERT_WHATSAPP_TO=
ORDER_ALERT_WEBHOOK_URL=
ORDER_ALERT_WEBHOOK_BEARER_TOKEN=
ORDER_ALERT_WEBHOOK_TIMEOUT_MS=7000
ORDER_ALERT_OPERATIONS_URL=https://querobroa.com.br/pedidos
DELIVERY_PICKUP_NAME=QUERO BROA
DELIVERY_PICKUP_PHONE=
DELIVERY_PICKUP_ADDRESS=Alameda Jau, 731 - Sao Paulo - SP, Brasil
# Origem operacional fixa em codigo: Alameda Jau, 731 - Sao Paulo - SP, Brasil
DELIVERY_MANUAL_FALLBACK_FEE=12
# Uber Direct prioritario ate o limite de cobertura da conta
UBER_DIRECT_BASE_URL=
UBER_DIRECT_BEARER_TOKEN=
UBER_DIRECT_API_BASE_URL=https://api.uber.com
UBER_DIRECT_TOKEN_URL=https://login.uber.com/oauth/v2/token
UBER_DIRECT_SCOPE=eats.deliveries
UBER_DIRECT_API_MODE=LEGACY_CUSTOMER
UBER_DIRECT_REQUEST_TIMEOUT_MS=12000
UBER_DIRECT_CLIENT_ID=
UBER_DIRECT_CLIENT_SECRET=
UBER_DIRECT_STORE_ID=
UBER_DIRECT_CUSTOMER_ID=
UBER_DIRECT_PICKUP_NAME=QUERO BROA
UBER_DIRECT_PICKUP_PHONE=
UBER_DIRECT_PICKUP_ADDRESS_LINE1=Alameda Jau, 731
UBER_DIRECT_PICKUP_ADDRESS_LINE2=
UBER_DIRECT_PICKUP_CITY=Sao Paulo
UBER_DIRECT_PICKUP_STATE=SP
UBER_DIRECT_PICKUP_POSTAL_CODE=
UBER_DIRECT_PICKUP_COUNTRY=BR
UBER_DIRECT_PICKUP_INSTRUCTIONS=
UBER_DIRECT_QUOTES_PATH=
UBER_DIRECT_DELIVERIES_PATH=
# Loggi como fallback automatico quando o Uber Direct recusar por cobertura
LOGGI_API_BASE_URL=https://api.loggi.com
LOGGI_AUTH_URL=
LOGGI_REQUEST_TIMEOUT_MS=12000
# Auth oficial da API
LOGGI_CLIENT_ID=
LOGGI_CLIENT_SECRET=
# Alternativa pragmatica via sessao Cognito do app Loggi
LOGGI_BEARER_TOKEN=
LOGGI_REFRESH_TOKEN=
LOGGI_COGNITO_CLIENT_ID=
LOGGI_COGNITO_REGION=us-east-1
LOGGI_COMPANY_ID=
LOGGI_EXTERNAL_SERVICE_ID=
LOGGI_FORCE_EXTERNAL_SERVICE_ID_ON_QUOTE=false
LOGGI_PICKUP_TYPE=PICKUP_TYPE_SPOT
LOGGI_DELIVERY_TYPE=DELIVERY_TYPE_CUSTOMER_DOOR
LOGGI_PICKUP_NAME=QUERO BROA
LOGGI_PICKUP_PHONE=
LOGGI_PICKUP_FEDERAL_TAX_ID=
LOGGI_PICKUP_ADDRESS_LINE1=Alameda Jau, 731
LOGGI_PICKUP_ADDRESS_LINE2=
LOGGI_PICKUP_CITY=Sao Paulo
LOGGI_PICKUP_STATE=SP
# line1/cidade/UF/pais da coleta sao fixos em codigo para garantir origem unica na Alameda Jau, 731
LOGGI_PICKUP_POSTAL_CODE=
LOGGI_PICKUP_COUNTRY=Brasil
LOGGI_PICKUP_INSTRUCTIONS=
LOGGI_DEFAULT_RECIPIENT_FEDERAL_TAX_ID=
LOGGI_PACKAGE_BASE_WEIGHT_G=1200
LOGGI_PACKAGE_WEIGHT_PER_ITEM_G=450
LOGGI_PACKAGE_LENGTH_CM=32
LOGGI_PACKAGE_WIDTH_CM=24
LOGGI_PACKAGE_HEIGHT_CM=14
LOGGI_PACKAGE_HEIGHT_STEP_CM=3
