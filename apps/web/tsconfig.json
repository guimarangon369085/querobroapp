{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "typeRoots": [
      "./node_modules/@types"
    ],
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    ".next-qa-browser-smoke/types/**/*.ts",
    ".next-qa-critical-e2e/types/**/*.ts",
    ".next-qa-trust/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "src"
  ],
  "exclude": [
    "node_modules"
  ]
}
